<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>Klorn</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!-- Export compliance: the app uses only standard HTTPS/TLS, which is exempt.
	     Declaring this here removes the manual prompt on every App Store upload. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Native push: allow the app to be woken by a remote notification. The
	     "Push Notifications" + "Background Modes" capabilities must also be added
	     in Xcode (they write the aps-environment entitlement, which needs signing). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<!-- OAuth deep-link relay (login-CSRF fix): lets the app receive the
	     ai.klorn.app://oauth-callback redirect. Dormant until the web build sets
	     NEXT_PUBLIC_NATIVE_OAUTH_SCHEME. See apps/mobile/OAUTH_RELAY.md. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>ai.klorn.app.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>ai.klorn.app</string>
			</array>
		</dict>
	</array>
	<!-- Voice input (@capacitor-community/speech-recognition): dictate chat
	     messages and calendar events. Speech is handled by Apple's on-device /
	     system speech APIs; the app receives only the transcribed text. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Klorn uses the microphone so you can dictate messages and calendar events by voice.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Klorn converts your speech to text to create calendar events and assistant messages. Audio is processed by Apple&apos;s speech recognition and is not stored by Klorn.</string>
</dict>
</plist>
