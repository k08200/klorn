{
  "name": "@klorn/mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Klorn native mobile shell (Capacitor) — wraps the hosted web app (app.klorn.ai) with native push (FCM) and on-device calendar (Samsung + Google).",
  "scripts": {
    "add:android": "cap add android",
    "add:ios": "cap add ios",
    "sync": "cap sync",
    "sync:probe": "KLORN_PROBE=1 cap sync",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android",
    "run:ios": "cap run ios"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@ebarooni/capacitor-calendar": "^8.2.0",
    "@revenuecat/purchases-capacitor": "^13.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "typescript": "^5.9.3"
  }
}
