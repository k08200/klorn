# Klorn self-host environment — used by docker-compose.selfhost.yml.
#
#   cp .env.selfhost.example .env.selfhost
#   docker compose --env-file .env.selfhost -f docker-compose.selfhost.yml up -d --build
#
# PLACEHOLDERS ONLY in this file — never commit real secrets.
# Full variable reference: docs/self-hosting.md

# ── Required ────────────────────────────────────────────────────────────

# Postgres password for the bundled postgres service (any strong string).
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing secret (any long random string).
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-long-random-string

# OAuth token encryption at rest — MUST decode to exactly 32 bytes (base64).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=change-me-base64-32-bytes

# Your OWN Google OAuth client (docs/self-hosting.md walks through creating it).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must exactly match the Authorized redirect URI on your OAuth client.
# Beyond localhost, use https://api.your-domain.example/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ── LLM provider — set at least ONE of the three blocks ─────────────────

# OpenRouter (free-tier models work): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini API key (failover / alternative).
GEMINI_API_KEY=

# Fully local (Ollama / LM Studio / vLLM — no email leaves your machine).
# NOTE: inside docker, "localhost" is the container — use host.docker.internal.
# OPENAI_COMPAT_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_COMPAT_MODEL=qwen3:8b
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_API_KEY=

# ── URLs (change all three together when serving beyond localhost) ──────

# Where browsers reach the web app (OAuth redirects land here).
WEB_URL=http://localhost:3000
# Browser origins allowed to call the API — must include WEB_URL's origin.
CORS_ORIGINS=http://localhost:3000
# Where browsers reach the API. Build-time value baked into the web bundle —
# changing it requires `up -d --build` to take effect.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Optional: real-time Gmail push (else 1-minute polling fallback) ─────
# Pub/Sub topic in the SAME GCP project as your OAuth client; grant
# roles/pubsub.publisher to gmail-api-push@system.gserviceaccount.com.
GMAIL_PUBSUB_TOPIC=
# Push-endpoint auth — pick ONE (OIDC preferred).
GMAIL_PUSH_OIDC_EMAIL=
GMAIL_PUSH_TOKEN=

# ── Optional: notifications ─────────────────────────────────────────────
# Web Push (browser/PWA). Generate a pair: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
# Telegram delivery for PUSH-tier interrupts (see README "Telegram notifications").
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# ── Optional: operator conveniences ─────────────────────────────────────
# Comma-separated emails that get admin access.
ADMIN_EMAILS=
# Model pins (defaults favor free/cheap models — see packages/api/.env.example).
JUDGE_MODEL=
CHAT_MODEL=
AGENT_MODEL=
