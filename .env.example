# Klorn — Environment Variables
# Copy to .env and fill in your values.
# These defaults match docker-compose.yml; if you change one, change both.

# Database — credentials match docker-compose.yml (user=klorn, db=klorn, port 5432).
DATABASE_URL=postgresql://klorn:klorn-local-dev@localhost:5432/klorn

# Auth
JWT_SECRET=change-me-in-production
# Comma-separated founder/operator emails that always get admin access.
ADMIN_EMAILS=

# OAuth Token Encryption (32-byte key, base64-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required in production. In development it falls back to a deterministic dev key.
TOKEN_ENCRYPTION_KEY=

# AI — OpenRouter (free models available)
OPENROUTER_API_KEY=
# Default to a free OpenRouter model for beta cost control.
# CHAT_MODEL=google/gemma-4-31b-it:free
# AGENT_MODEL=google/gemma-4-31b-it:free
# FALLBACK_MODEL=google/gemma-4-31b-it:free
# Tier judge (the attention firewall's classifier). Defaults to a cheap PAID
# model: :free daily quotas lock the provider out mid-day and the keyword
# fallback cannot emit PUSH, so urgent mail silently stops interrupting.
# ~700 tokens/email ≈ cents per month at personal volume. No paid credit?
# Point it at a :free or local model instead:
# JUDGE_MODEL=google/gemini-2.5-flash
# JUDGE_MODEL=google/gemma-4-31b-it:free
# Judge dial (optional): a STRONGER model to escalate to only when the cheap
# JUDGE_MODEL reports low confidence (< 0.5) on an email — "frontier only on the
# blind spot". Unset = off (single-model judge, the default). Set this to run a
# cheap/local JUDGE_MODEL for the easy mass and spend a frontier model only on
# the genuinely ambiguous mail. Escalations log a cheap-vs-strong delta line.
# JUDGE_ESCALATION_MODEL=anthropic/claude-sonnet-4

# Stripe (optional — billing features)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# Paywall master switch. Unset/false = every gated feature is free and the
# entitlement guards are no-ops (safe default for self-host and pre-launch).
# Flip to "true" at launch — see docs/launch/paywall-flip-runbook.md.
# PAYWALL_ENABLED=false
# Free-tier daily LLM spend cap in cents; only applies while PAYWALL_ENABLED
# is true and the user is not entitled. Default 10 (= $0.10/day).
# FREE_DAILY_COST_CAP_CENTS=10
# Stripe checkout trial length in days (default 7).
# TRIAL_DAYS=7

# GitHub attention source (optional) — no env needed. Each user connects
# their own personal access token (scope: notifications, + repo for private)
# at runtime via POST /api/github/connect; it's stored encrypted with
# TOKEN_ENCRYPTION_KEY. The poller surfaces GitHub notifications into the
# same firewall queue as email.

# Google OAuth (optional — Gmail/Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Gmail Pub/Sub push (optional — real-time inbox sync instead of 1-minute polling)
# Topic must exist in the same GCP project and grant roles/pubsub.publisher
# to gmail-api-push@system.gserviceaccount.com.
#
# Auth: pick ONE of the two below. Auth headers, NEVER query strings.
#   (preferred) GMAIL_PUSH_OIDC_EMAIL — the Pub/Sub push subscription should
#     be configured with "Authentication" enabled using a service account.
#     We verify the OIDC token (issuer accounts.google.com, exp, email match).
#   (fallback) GMAIL_PUSH_TOKEN — shared secret sent as
#     `Authorization: Bearer <token>` in the Pub/Sub HTTP push.
GMAIL_PUBSUB_TOPIC=
GMAIL_PUSH_OIDC_EMAIL=
GMAIL_PUSH_TOKEN=

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Notion (optional)
NOTION_API_KEY=

# Frontend
# FRONTEND_URL / WEB_URL — URL of the Next.js web app (used by API for OAuth redirects)
FRONTEND_URL=http://localhost:8001
WEB_URL=http://localhost:8001
# NEXT_PUBLIC_API_URL — URL of the Fastify API server (used by Next.js client code)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Web Push (optional — iOS/PWA/browser notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:hello@klorn.ai
# Optional override for service-worker delivery receipts.
# Defaults to RENDER_EXTERNAL_URL on Render.
PUSH_RECEIPT_BASE_URL=

# Beta access flags
# When BETA_GATE_ENABLED=true, registration is restricted to APPROVED waitlist
# entries and approved registrants are auto-granted PRO. Default: unset (open).
BETA_GATE_ENABLED=
# When BETA_AUTO_PRO_ENABLED=true (and the gate above is OFF), the first
# BETA_AUTO_PRO_LIMIT signups silently get PRO. Past the cap they fall back to
# FREE — no error. Use this for short, link-shared private betas while the LLM
# stack is on free models. Turn OFF before public launch or before switching
# the gate ON.
BETA_AUTO_PRO_ENABLED=
BETA_AUTO_PRO_LIMIT=50

# Development-only: allow anonymous requests to fall back to a seeded
# demo-user account. OFF by default — set to "true" only when you want a
# zero-auth local dev experience. Ignored in production.
ENABLE_DEMO_USER=

# ── Engine tuning (optional overrides for src/config.ts) ──────────────
# Defaults match the values audited in 2026-05-19; override only when you
# need to tune behavior without a code deploy.
# PUSH_CAP_10MIN=3
# PUSH_CAP_60MIN=6
# PUSH_WINDOW_10MIN_MS=600000
# PUSH_WINDOW_60MIN_MS=3600000
# PROACTIVE_UNANSWERED_HOURS=48
# PROACTIVE_MEETING_PREP_MIN=60
# PROACTIVE_DEADLINE_WARN_DAYS=3
# PROACTIVE_EOD_HOUR=18
# PROACTIVE_WEEKLY_DAY=1
# PATTERN_ANALYSIS_HOURS=168
# PATTERN_MIN_OCCURRENCES=3
# TRUST_MIN_DATA_POINTS=3
# TRUST_RELIABLE_THRESHOLD=0.8
# TRUST_MOSTLY_RELIABLE_THRESHOLD=0.5
# TRUST_HALF_LIFE_DAYS=60
# FEEDBACK_DISMISS_THRESHOLD=4
# FEEDBACK_WINDOW_DAYS=30
# AGENT_CHECK_INTERVAL_MS=60000
# AGENT_MAX_TOOLS_PER_LOOP=10
# AGENT_MAX_CONTEXT_ITEMS=10
# DAILY_COST_CAP_CENTS=100  # per-user daily LLM spend cap; 0 to disable
# EMAIL_CLASSIFY_BATCH_SIZE=15
# SCHEDULER_CHECK_INTERVAL_MS=60000
# SCHEDULER_EMAIL_SYNC_INTERVAL_MS=180000
# SCHEDULER_CALENDAR_SYNC_INTERVAL_MS=900000
# SCHEDULER_RECONCILE_INTERVAL_MS=1800000
# SCHEDULER_WATCH_RENEWAL_INTERVAL_MS=3600000
