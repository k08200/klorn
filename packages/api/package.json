{
  "name": "@klorn/api",
  "version": "0.3.0",
  "private": true,
  "description": "Klorn API server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "sh scripts/start.sh",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "backfill:from-address": "tsx scripts/backfill-from-address.ts",
    "calibration": "tsx scripts/calibration.ts",
    "decision-metrics": "tsx scripts/decision-metrics.ts",
    "eval:judge": "tsx scripts/poc-accuracy.ts --in=eval/judge-eval-set.json --concurrency=1 --delay=4500",
    "eval:judge:body": "tsx scripts/poc-accuracy.ts --in=eval/judge-body-eval-set.json --compare-body --concurrency=1 --delay=4500"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.1",
    "@prisma/client": "^6.8.2",
    "@sentry/node": "^10.48.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.8.5",
    "firebase-admin": "^14.1.0",
    "googleapis": "^171.4.0",
    "imapflow": "^1.3.3",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.29.0",
    "resend": "^6.10.0",
    "sanitize-html": "^2.17.4",
    "stripe": "^18.1.0",
    "twilio": "^6.0.2",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/sanitize-html": "^2.16.1",
    "prisma": "^6.8.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "type": "module"
}
