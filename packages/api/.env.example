# Database
# Default matches the bundled docker-compose.yml so `docker compose up -d
# postgres` works out of the box. If you want to run a Postgres you
# already own, override accordingly.
#
# For Neon (serverless Postgres) in production, append these query params
# to survive cold-starts and avoid prepared-statement issues with PgBouncer:
#   ?pgbouncer=true&connect_timeout=15&connection_limit=1
# Example:
#   DATABASE_URL="postgresql://user:pw@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true&connect_timeout=15&connection_limit=1"
DATABASE_URL="postgresql://klorn:klorn-local-dev@localhost:5432/klorn"

# Keep off on Neon/Render free tiers; true makes the DB effectively always-on.
DB_HEARTBEAT_ENABLED=false

# Server
PORT=8000
# Comma-separated founder/operator emails that always get admin access.
ADMIN_EMAILS=""

# Web app URL (for OAuth redirects)
WEB_URL="http://localhost:8001"

# Transactional email (Resend) — verification, password reset, beta invites,
# and the founder welcome email. Without RESEND_API_KEY every sender is a
# graceful no-op (links are logged, nothing is sent), so local dev needs none.
# RESEND_API_KEY=""
# FROM_EMAIL="Klorn <onboarding@yourdomain.com>"   # must be a Resend-verified sender
#
# Founder welcome email — auto-sent once per user on first Google sign-in or on
# email verification. All optional:
#   FOUNDER_NAME    — sender display name + signoff (empty → neutral team voice)
#   FOUNDER_TITLE   — line under the signoff (default "Founder")
#   FOUNDER_REPLY_TO— where "just hit reply" lands (default: first ADMIN_EMAILS)
#   WELCOME_FROM_EMAIL — override the From for this one email (default FROM_EMAIL)
#   COMMUNITY_URL   — Slack/Discord invite; the invite line is omitted if unset
# FOUNDER_NAME=""
# FOUNDER_TITLE="Founder"
# FOUNDER_REPLY_TO=""
# WELCOME_FROM_EMAIL=""
# COMMUNITY_URL=""

# LLM (OpenRouter — primary provider)
OPENROUTER_API_KEY=""
# Default free model for beta cost control.
# CHAT_MODEL="google/gemma-4-31b-it:free"
# AGENT_MODEL="google/gemma-4-31b-it:free"
# Tier judge + reply drafting default to a reliable (paid) model — a :free
# daily-quota lockout otherwise breaks PUSH classification and "Draft reply".
# Point these at a :free or local model if you have no paid credit.
# JUDGE_MODEL="google/gemini-2.5-flash"
# DRAFT_MODEL="google/gemini-2.5-flash"
# Fallback free model when OpenRouter credits are exhausted (402)
FALLBACK_MODEL="google/gemma-4-31b-it:free"

# Gemini (Google AI Studio) — secondary provider used when OpenRouter
# returns 403 "Key limit exceeded (weekly limit)". Completely free quota,
# independent of OpenRouter. Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# GEMINI_FALLBACK_MODEL="gemini-2.5-flash"

# Local LLM (any OpenAI-compatible endpoint: Ollama, LM Studio, vLLM,
# llama.cpp server). When set, classification runs against it FIRST and
# your email content never leaves your machine; cloud providers above (if
# configured) act as failover only. Set OPENAI_COMPAT_PRIORITY=last to use
# the local endpoint as the fallback instead.
# Ollama example:  OPENAI_COMPAT_BASE_URL="http://localhost:11434/v1"
OPENAI_COMPAT_BASE_URL=""
# OPENAI_COMPAT_MODEL="qwen3:8b"
# OPENAI_COMPAT_API_KEY=""           # most local servers ignore auth
# OPENAI_COMPAT_PRIORITY="first"     # "first" (default) | "last"
# OPENAI_COMPAT_SUPPORTS_TOOLS=false # opt in only if your model handles tools

# File conversion
# Results are persisted on disk for 7 days by default.
# EVE_CONVERSION_STORAGE_DIR="./data/file-conversions"
# EVE_CONVERSION_RESULT_TTL_MS=604800000
# EVE_CONVERTER_TIMEOUT_MS=60000
#
# Layout-preserving Office/PDF export. If unset, EVE auto-detects soffice/libreoffice
# from PATH and common macOS install paths.
# EVE_LIBREOFFICE_BIN="/Applications/LibreOffice.app/Contents/MacOS/soffice"
#
# Raster image re-encoding. If unset, EVE auto-detects ImageMagick `magick`.
# EVE_IMAGE_CONVERTER_BIN="/opt/homebrew/bin/magick"
# EVE_IMAGE_CONVERTER_ARGS="[\"{input}\",\"{output}\"]"
#
# CAD conversion. DWG usually requires a commercial/server CAD converter.
# DXF can also auto-detect pstoedit when installed.
# DWG can also be produced as PDF→DXF→DWG when ODA File Converter is installed
# or when EVE_DXF_TO_DWG_BIN is configured.
# EVE_PDF_TO_DWG_BIN="/path/to/pdf-to-dwg"
# EVE_PDF_TO_DWG_ARGS="[\"{input}\",\"{output}\"]"
# EVE_PDF_TO_DXF_BIN="/path/to/pdf-to-dxf"
# EVE_PDF_TO_DXF_ARGS="[\"{input}\",\"{output}\"]"
# EVE_DXF_TO_DWG_BIN="/Applications/ODAFileConverter.app/Contents/MacOS/ODAFileConverter"
# EVE_DXF_TO_DWG_ARGS="[\"{input}\",\"{output}\"]"

# Google OAuth (Gmail + Calendar)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (Billing)
STRIPE_SECRET_KEY=""

# Telegram notifications (Optional — see README "Telegram notifications")
# BYO bot via @BotFather. PUSH-tier interrupts are mirrored to the linked
# chat; works without VAPID keys for web-push-free self-hosts.
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_BOT_USERNAME=""
# Required to enable the webhook endpoint; pass the same value as
# secret_token to setWebhook. Generate: openssl rand -hex 32
# TELEGRAM_WEBHOOK_SECRET=""

# Native push / FCM (Optional — required for the Capacitor mobile shell,
# apps/mobile, to deliver push to Android). The full Firebase service-account
# JSON as a single-line string:
#   Firebase console → Project settings → Service accounts → Generate new
#   private key. Absent → Android native push is skipped (logged), like VAPID.
# FIREBASE_SERVICE_ACCOUNT=""

# Native iOS push / APNs (Optional — required for iOS push in the Capacitor
# shell). iOS device tokens are raw APNs tokens (not FCM), so they go straight
# to Apple. Create an APNs auth key (.p8) in the Apple Developer portal.
# APNS_KEY_P8 holds the .p8 contents (newlines as literal \n are accepted).
# Absent → iOS push is skipped (logged), like missing FCM/VAPID.
# APNS_KEY_P8=""
# APNS_KEY_ID=""
# APNS_TEAM_ID=""
# APNS_BUNDLE_ID="ai.klorn.app"
# APNS_PRODUCTION="false"   # "true" for TestFlight/App Store builds; sandbox otherwise

# Phone escalation v0 (Optional — BYO Twilio, off by default)
# One plain TTS call when a PUSH-tier push goes unacknowledged. Opt-in
# per user on top of this global flag. Quiet hours ALWAYS suppress calls.
# Each call costs real money (~$0.02–0.06 depending on destination country).
# PHONE_ESCALATION_ENABLED=false
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""           # E.164, e.g. +15555550000
# PUBLIC_URL=""                   # public HTTPS base URL of THIS API — Twilio
#                                 # must reach $PUBLIC_URL/api/phone/gather
# PHONE_ESCALATION_DAILY_CAP=3    # hard per-user daily call cap
# PHONE_ESCALATION_TIMEOUT_MINUTES=5  # unacked minutes before dialing

# Slack (Optional)
SLACK_BOT_TOKEN=""
SLACK_WEBHOOK_URL=""
SLACK_SIGNING_SECRET=""

# Notion (Optional — coming soon)
# NOTION_API_KEY=""
