generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

model User {
  id                        String                     @id @default(uuid())
  email                     String                     @unique
  passwordHash              String?
  name                      String?
  role                      UserRole                   @default(USER)
  plan                      Plan                       @default(FREE)
  chatModel                 String                     @default("google/gemma-4-31b-it:free")
  agentModel                String?
  openRouterApiKey          String?
  geminiApiKey              String?
  // Naver IMAP connection (Korean ICP support).
  // OAuth is intentionally skipped — Naver issues a separate "외부 메일
  // 가져오기 비밀번호" the user generates in their Naver settings; we
  // store the encrypted form so a DB leak doesn't expose the live IMAP
  // password. Host defaults to imap.naver.com:993 (SSL) but is
  // overridable for other IMAP providers in the future.
  naverImapEmail            String?
  naverImapPasswordCipher   String?
  naverImapHost             String?
  naverImapConnectedAt      DateTime?
  // Telegram delivery (self-hoster BYO bot via BotFather).
  // telegramChatId is the bound chat for outbound PUSH-tier interrupts —
  // unique so a chat can only ever belong to one account. telegramLinkCode
  // is a one-time crypto-random code minted by POST /api/telegram/link and
  // consumed by the bot webhook's `/start <code>` handler within 10 minutes.
  telegramChatId            String?                    @unique
  telegramLinkCode          String?                    @unique
  telegramLinkCodeExpiresAt DateTime?
  stripeId                  String?                    @unique
  emailVerified             Boolean                    @default(false)
  verifyToken               String?
  verifyTokenExp            DateTime?
  resetToken                String?
  resetTokenExp             DateTime?
  betaProGrantedAt          DateTime?
  conversations             Conversation[]
  tokens                    UserToken[]
  tasks                     Task[]
  notes                     Note[]
  reminders                 Reminder[]
  contacts                  Contact[]
  calendarEvents            CalendarEvent[]
  automationConfig          AutomationConfig?
  agentLogs                 AgentLog[]
  notifications             Notification[]
  pushSubscriptions         PushSubscription[]
  pushDeliveryLogs          PushDeliveryLog[]
  pushRingEvents            PushRingEvent[]
  phoneEscalations          PhoneEscalation[]
  memories                  Memory[]
  skills                    Skill[]
  tokenUsages               TokenUsage[]
  devices                   Device[]
  emailMessages             EmailMessage[]
  emailAttachments          EmailAttachment[]
  candidateIntakes          CandidateIntake[]
  emailRules                EmailRule[]
  attentionItems            AttentionItem[]
  commitments               Commitment[]
  feedbackEvents            FeedbackEvent[]
  emailLabelFeedback        EmailLabelFeedback[]
  playbookActivations       ActivatedPlaybook[]
  workContextSnapshots      WorkContextSnapshot[]
  feedbackPolicyPreferences FeedbackPolicyPreference[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  emailProcessingLogs       EmailProcessingLog[]
  contactTrustScores        ContactTrustScore[]
  llmCostLedger             LlmCostLedger[]
  llmUsageLogs              LlmUsageLog[]
}

enum UserRole {
  USER
  ADMIN
}

model Device {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique // SHA-256 hash of the JWT token
  deviceName   String? // e.g. "Chrome on macOS", "iPhone 15"
  deviceType   String   @default("web") // "web" | "desktop" | "mobile"
  ipAddress    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
}

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

model Conversation {
  id             String                @id @default(uuid())
  title          String?
  pinned         Boolean               @default(false)
  source         String                @default("user") // "user" | "agent"
  userId         String
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]
  pendingActions PendingAction[]
  tokenUsages    TokenUsage[]
  summaries      ConversationSummary[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([userId, updatedAt])
}

model Message {
  id             String         @id @default(uuid())
  conversationId String
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           Role
  content        String
  // JSONB after migration 20260519070000. Shape varies by source:
  //   { source: "agent" | "user" | "chat", hasAction?, actionResult?,
  //     actionFailed?, actionRejected?, pendingActionId?: string }
  metadata       Json?
  pendingAction  PendingAction?
  createdAt      DateTime       @default(now())

  @@index([content(ops: raw("gin_trgm_ops"))], map: "Message_content_trgm_idx", type: Gin)
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

model UserToken {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider            String // "google"
  accessToken         String
  refreshToken        String?
  expiresAt           DateTime?
  // Gmail push watch (users.watch) expires ~7 days after registration.
  // Null means the user has not enabled real-time push.
  gmailWatchExpiresAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([userId, provider])
}

model Task {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, status, dueDate])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, category])
}

model Reminder {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  remindAt    DateTime
  status      ReminderStatus @default(PENDING)
  createdAt   DateTime       @default(now())

  @@index([userId, status, remindAt])
}

enum ReminderStatus {
  PENDING
  SENT
  DISMISSED
}

model Contact {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  company   String?
  role      String?
  notes     String?
  tags      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, name])
  @@index([userId, email])
}

model CalendarEvent {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  meetingLink String?
  color       String?
  allDay      Boolean  @default(false)
  googleId    String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, startTime])
}

model AutomationConfig {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetingAutoJoin      Boolean  @default(true)
  meetingAutoSummarize Boolean  @default(true)
  emailAutoClassify    Boolean  @default(true)
  reminderAutoCheck    Boolean  @default(true)
  dailyBriefing        Boolean  @default(true)
  briefingTime         String   @default("06:00")
  timezone             String   @default("Asia/Seoul")
  downloadAutoOrganize Boolean  @default(false)
  autonomousAgent      Boolean  @default(true)
  agentMode            String   @default("SUGGEST") // "SHADOW" | "SUGGEST" | "AUTO"
  agentIntervalMin     Int      @default(5)
  alwaysAllowedTools   String[] @default([]) // MEDIUM-risk tools the user has pre-approved for AUTO mode
  // Gmail read-state opt-in: when true, Eve marks the original email as read
  // after AUTO-replying to it. Default off so Gmail's "unread" remains a user signal.
  autoMarkReadEnabled  Boolean  @default(false)
  // Notification preferences — granular opt-out by category
  notifyEmailUrgent    Boolean  @default(true) // urgent email alerts
  notifyMeeting        Boolean  @default(true) // meeting reminders
  notifyTaskDue        Boolean  @default(true) // task due soon/overdue
  notifyAgentProposal  Boolean  @default(true) // autonomous agent proposals
  notifyDailyBriefing  Boolean  @default(true) // daily briefing notification
  notifyEmailCandidate Boolean  @default(true) // candidate/profile attachment intake alerts
  quietHoursStart      String? // "22:00" — suppress push during this window
  quietHoursEnd        String? // "08:00"
  // Phone escalation v0 opt-in. Default false: a phone call is the most
  // intrusive delivery channel Klorn has — nobody gets dialed without
  // explicitly flipping this on (and PHONE_ESCALATION_ENABLED=true globally).
  phoneEscalationEnabled Boolean @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AgentLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String // "notify" | "tool_call" | "skip" | "error"
  tool      String? // tool name if action is tool_call
  summary   String // what the agent decided/did
  reasoning String? // LLM's reasoning
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Tracks Eve's processing of individual emails (SUGGEST vs AUTO, which action taken).
// Used to distinguish "Eve touched this" vs "Gmail native read state" so users can
// opt into auto-mark-read without losing their fallback inbox signal.
model EmailProcessingLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailId     String // EmailMessage.id (soft reference — no FK so we can retain history if email is deleted)
  mode        String // "SHADOW" | "SUGGEST" | "AUTO"
  action      String // "mark_read" | "reply" | "classify" | "archive"
  processedAt DateTime @default(now())

  @@index([userId, emailId])
  @@index([userId, processedAt])
}

model Notification {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String // "reminder" | "calendar" | "email" | "task" | "meeting" | "briefing" | "agent_proposal"
  title           String
  message         String
  isRead          Boolean        @default(false)
  link            String? // URL path to navigate when clicked (e.g. "/chat/abc-123", "/calendar")
  // Structured source links — populated when known, NULL for legacy notifications
  conversationId  String? // for notifications tied to a chat conversation
  sourceEmailId   String? // EmailMessage.id for email-originated notifications
  pendingActionId String?        @unique // FK to PendingAction for inline approve/reject in drawer
  pendingAction   PendingAction? @relation(fields: [pendingActionId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@index([pendingActionId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  // Web origin where the SW that owns this subscription is registered (e.g.
  // "https://app.klorn.ai"). Required so the backend can stop pushing to
  // subs belonging to retired origins whose SW would openWindow() to a
  // dead URL. Nullable for rows created before this column existed; clean
  // those up via scripts/cleanup-stale-push-subs.ts.
  origin    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PushDeliveryLog {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  notificationId  String?
  endpointHost    String?
  category        String    @default("system")
  title           String
  status          String    @default("PENDING") // PENDING | ACCEPTED | FAILED | SKIPPED
  skipReason      String?
  errorStatusCode Int?
  errorBody       String?
  acceptedAt      DateTime?
  receivedAt      DateTime?
  clickedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([subscriptionId])
}

// Persistent push rate-limit window. One row per allowed "ring" — a logical
// notification dispatch that passed every gate — so the per-user caps
// survive process restarts and horizontal scaling. Rows older than the
// widest window are pruned opportunistically on each allowed attempt.
model PushRingEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Phone escalation v0 — ONE plain TTS call when a PUSH-tier push goes
// unacknowledged. This is a DELIVERY channel for the PUSH tier, not a 5th
// tier (tiers.ts vocabulary is locked). The UNIQUE index on notificationId
// is the hard "max one call per notification, ever" rail — racing scheduler
// ticks collapse into a single row instead of a double dial.
model PhoneEscalation {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationId String    @unique // Notification.id (soft reference, like EmailProcessingLog.emailId)
  gatherToken    String    @unique // capability token embedded in the <Gather> action URL
  title          String // sanitized spoken title — re-<Say> source for "press 1"
  status         String    @default("PLACED") // PLACED | ANSWERED | ACKNOWLEDGED | FAILED
  twilioCallSid  String?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, createdAt])
}

// Memory System — Eve remembers facts about each user across conversations
// Inspired by Claude Code's memdir/ persistent memory architecture
model Memory {
  id         String     @id @default(uuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       MemoryType
  key        String // short label, e.g. "preferred_language"
  content    String // the remembered fact
  source     String? // which conversation/context it came from
  confidence Float      @default(1.0) // 0-1, lower for inferred facts
  lastUsedAt DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([userId, type, key])
  @@index([userId, type])
}

enum MemoryType {
  PREFERENCE // user preferences (language, tone, schedule)
  FACT // facts about the user (name, company, role)
  DECISION // past decisions the user made
  CONTEXT // ongoing project/work context
  FEEDBACK // corrections or instructions from user
}

// Reusable workflows the user defines for Eve to execute
model Skill {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key         String // slugified name, e.g. "weekly_report"
  name        String
  description String   @default("")
  prompt      String // template, may include {{variable}} placeholders
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
}

// Token Usage Tracking — per-conversation and per-user cost tracking
// Inspired by Claude Code's cost-tracker.ts
model TokenUsage {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId   String?
  conversation     Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  model            String // e.g. "google/gemma-4-31b-it:free"
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCost    Float         @default(0) // USD
  createdAt        DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([conversationId])
}

// Conversation Summary — compressed history for long conversations
// Inspired by Claude Code's services/compact/ auto-compaction
model ConversationSummary {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  summary        String // compressed summary of messages
  messageCount   Int // how many messages were summarized
  upToMessageId  String // last message ID included in summary
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

// Pending Action — Eve's proposals awaiting user approval
// Agent creates these when it wants to take action on behalf of the user
model PendingAction {
  id             String        @id @default(uuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String        @unique
  message        Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId         String
  status         ActionStatus  @default(PENDING)
  toolName       String // e.g. "create_reminder", "update_task"
  // JSONB after migration 20260519060000. Always an object payload; the
  // exact shape depends on toolName (tool-executor.ts dispatches on it).
  toolArgs       Json
  reasoning      String? // Why Eve suggests this action
  // Result payload from executeToolCall. Free-form string (tool's
  // return value) — leaving as text keeps the column open for any tool
  // that returns a non-JSON message.
  result         String?
  // Reject-with-feedback (HITL): the user's stated "why" captured at
  // reject time (≤500 chars, trimmed). NULL for rejections without a
  // reason and for legacy rows. Surfaced back into agent prompts via
  // rejection-hint.ts so the agent stops repeating rejected proposals.
  rejectionReason String?
  // Deterministic floor: ActionReceipt minted at /approve time for floor
  // actions (see attention-floor.ts). NULL for non-floor actions and for
  // legacy rows pre-#481. tool-executor verifies this against the
  // about-to-execute payload bytes and refuses on mismatch.
  actionReceipt  Json?
  notification   Notification?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId, status])
  @@index([conversationId])
}

enum ActionStatus {
  PENDING
  REJECTED
  EXECUTED
  FAILED
}

// ─── Email System ──────────────────────────────────────────────────────────
// Persisted copy of Gmail messages for local search, AI summarization, and threading

model EmailMessage {
  id                   String        @id @default(uuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  gmailId              String // Gmail message ID
  threadId             String? // Gmail thread ID for conversation grouping
  from                 String
  to                   String
  cc                   String?
  subject              String
  snippet              String? // Gmail snippet (preview text)
  body                 String? // Full plain-text body
  htmlBody             String? // Full HTML body (for rich rendering)
  labels               String[] // Gmail labels: ["INBOX", "UNREAD", "IMPORTANT"]
  isRead               Boolean       @default(false)
  isStarred            Boolean       @default(false)
  priority             EmailPriority @default(NORMAL)
  category             String? // AI classification: billing, meeting, engineering, conversation, automated, other
  summary              String? // AI-generated one-line summary
  // JSONB after migration 20260519040000. Always a `string[]` payload
  // when present (AI-extracted bullet points / TODOs); `null` when EVE
  // has not summarized the email yet.
  keyPoints            Json?
  actionItems          Json?
  needsReply           Boolean       @default(false)
  needsReplyReason     String?
  needsReplyConfidence Float         @default(0.0)
  sentiment            String? // positive | negative | neutral
  receivedAt           DateTime // Original email date
  syncedAt             DateTime      @default(now()) // When we synced from Gmail
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  attachments          EmailAttachment[]
  candidateIntakes     CandidateIntake[]

  @@unique([userId, gmailId])
  @@index([userId, receivedAt])
  @@index([userId, threadId])
  @@index([userId, priority])
  @@index([userId, category])
  @@index([userId, isRead])
  @@index([userId, needsReply])
}

model EmailAttachment {
  id                String       @id @default(uuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailId           String
  email             EmailMessage @relation(fields: [emailId], references: [id], onDelete: Cascade)
  gmailAttachmentId String
  filename          String
  mimeType          String
  size              Int?
  contentText       String?
  summary           String?
  // JSONB after migration 20260519050000. `keyPoints` is a `string[]`;
  // `extractedFields` is a flat object Record<string, string|number|boolean|null>.
  keyPoints         Json?
  extractedFields   Json?
  category          String?
  analysisStatus    String       @default("PENDING")
  analysisError     String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([emailId, gmailAttachmentId])
  @@index([userId, createdAt])
  @@index([emailId])
  @@index([userId, category])
  @@index([userId, analysisStatus])
}

model CandidateIntake {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailId        String
  email          EmailMessage @relation(fields: [emailId], references: [id], onDelete: Cascade)
  status         String       @default("READY_TO_REVIEW") // NEEDS_ANALYSIS | NEEDS_INFO | READY_TO_REVIEW | REVIEWING | CONTACTED | SHORTLISTED | REJECTED | ARCHIVED
  name           String?
  role           String?
  contact        String?
  emailAddress   String?
  phone          String?
  summary        String
  confidence     Float        @default(0.0)
  missingFields  Json         @default("[]")
  evidenceFiles  Json         @default("[]")
  notes          String?
  lastDetectedAt DateTime     @default(now())
  reviewedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, emailId])
  @@index([userId, status, updatedAt])
  @@index([emailId])
}

// User-supplied corrections of Eve's automatic email priority classification.
// Each row captures both the auto-label that was wrong AND the heuristic
// signals/reason at the moment of feedback, so we can later replay the
// classifier against these cases as a regression suite or feed them in as
// few-shot examples without losing why the model was originally fooled.
model EmailLabelFeedback {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailId           String // EmailMessage.id (soft FK — keep history if email is deleted)
  originalPriority  EmailPriority // priority Eve assigned at the moment of feedback
  correctedPriority EmailPriority // priority the user intended
  reason            String? // classifyPriorityDetailed.reason snapshot (or "auto" if pre-detailed)
  signals           String[] // classifyPriorityDetailed.signals snapshot
  fromAddress       String // sender at feedback time — for fixture export
  subject           String // subject at feedback time — for fixture export
  labels            String[] // gmail labels at feedback time
  note              String? // optional free-text comment from the user
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([userId, emailId])
  @@index([userId, createdAt])
}

enum EmailPriority {
  URGENT
  NORMAL
  LOW
}

// Auto-reply rules — user-configurable patterns for automated responses
model EmailRule {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String // Rule display name
  description     String?
  isActive        Boolean         @default(true)
  // Conditions: { from?: string[], subjectContains?: string[], category?: string[] }
  // Stored as native JSONB so the matching engine can rely on the
  // shape (no per-row JSON.parse) and so a future PR can index/query
  // individual keys without rewriting every row.
  conditions      Json
  // Action type
  actionType      EmailRuleAction @default(AUTO_REPLY)
  // Reply template (for AUTO_REPLY) or label name (for LABEL)
  actionValue     String
  // How many times this rule has been triggered
  triggerCount    Int             @default(0)
  lastTriggeredAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, isActive])
}

enum EmailRuleAction {
  AUTO_REPLY // Send canned reply
  DRAFT_REPLY // Create draft for user review
  LABEL // Apply label
  ARCHIVE // Auto-archive
  NOTIFY // Send push notification
}

// ─── Attention Queue ──────────────────────────────────────────────────────
// Unified queue of "things the user should look at." Replaces the ad-hoc join
// of PendingAction/Task/CalendarEvent/Notification used by /api/inbox/summary.
//
// Notification stays as the bell. AttentionItem is the work queue — what Eve
// believes you would lose value by missing.
//
// This first migration only adds the table. Producers and consumers land in
// follow-up PRs so the schema can be reviewed in isolation.

model AttentionItem {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Which underlying signal this row represents. (source, sourceId) is unique
  // so a given PendingAction/Task/etc. only ever has one AttentionItem.
  source   AttentionSource
  sourceId String

  type          AttentionType
  status        AttentionStatus @default(OPEN)
  // Priority is a 0-100 integer so callers can sort without picking a scale.
  // Default 50 = medium; producers can override deterministically.
  priority      Int             @default(50)
  // Confidence in the classification (0.0-1.0). 1.0 for hand-built items
  // (PendingAction → AttentionItem), <1.0 for inferred ones (e.g. Eve-derived).
  confidence    Float           @default(1.0)
  // Autopilot Ladder rung this item is allowed to act at. 0 = observe only,
  // 5 = exception-only. Default 1 = suggest.
  autonomyLevel Int             @default(1)

  title           String
  body            String?
  suggestedAction String? // Human-readable: "Reply to Sarah", "Reschedule"
  costOfIgnoring  String? // "Misses close window", "Loses Q2 budget"
  evidence        Json? // Supporting links/snippets backing the judgment

  // 5-tier escalation policy. Populated by attention-mirror tier selector.
  // SILENT = recorded only | QUEUE = inbox only, no push | PUSH = send push
  // AUTO = auto-handled, no interrupt | null = legacy / not yet classified
  tier       String? // "SILENT" | "QUEUE" | "PUSH" | "AUTO"
  tierReason String? // why this tier was chosen

  // Content-addressed classification. Hash of the decision-relevant input
  // bytes (from, subject, snippet, labels) at the moment tier was decided.
  // Read paths must re-hash the current input and compare; mismatch means
  // the input was mutated after classification and the cached tier is
  // stale (silent re-invocation risk, see dev.to thread + content-hash
  // doctrine in attention-input-hash.ts).
  inputHash   String? // sha256 hex, 64 chars
  inputHashAt DateTime? // when the hash was computed

  surfacedAt      DateTime  @default(now())
  resolvedAt      DateTime?
  snoozedUntil    DateTime?
  lastAmplifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, sourceId])
  @@index([userId, status, surfacedAt])
  @@index([userId, tier, surfacedAt])
}

enum AttentionSource {
  PENDING_ACTION
  TASK
  CALENDAR_EVENT
  NOTIFICATION
  COMMITMENT
  // POC firewall: each EmailMessage that poc-judge classifies surfaces as
  // its own AttentionItem with source=EMAIL, sourceId=EmailMessage.id.
  EMAIL
}

enum AttentionType {
  REPLY_NEEDED
  MEETING_PREP
  RISK
  DEADLINE
  FOLLOWUP
  DECISION
  COMMITMENT_DUE
  COMMITMENT_UNCONFIRMED
  COMMITMENT_OVERDUE
}

enum AttentionStatus {
  OPEN
  RESOLVED
  DISMISSED
  SNOOZED
}

// ─── Commitment Ledger ─────────────────────────────────────────────────────
// "내일까지 보내드릴게요", "다음 주에 다시 논의하죠" — implicit promises that
// would otherwise vanish into a thread. The ledger is the canonical record;
// AttentionItem is just the projection of "currently relevant" commitments.

model Commitment {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  status      CommitmentStatus @default(OPEN)
  kind        CommitmentKind   @default(DELIVERABLE)
  // Who owes the action. USER = "I will send X" (we owe), COUNTERPARTY = "Sarah
  // will send X" (they owe), TEAM = shared, UNKNOWN = couldn't tell.
  owner       CommitmentOwner  @default(USER)

  counterpartyName  String?
  counterpartyEmail String? // lowercased sender email; set by ingestion pipeline
  contactId         String?

  // The promise: parsed dueAt is the machine-usable form, dueText preserves
  // the original phrasing ("end of week", "다음 주") for display.
  dueAt   DateTime?
  dueText String?

  // Where the commitment came from. sourceId is a free-text reference into
  // the source system (Gmail message id, Slack ts, etc.) and threadId groups
  // related commitments from the same conversation.
  sourceType   CommitmentSource @default(EMAIL)
  sourceId     String?
  threadId     String?
  evidenceText String? // Snippet from the source backing the extraction

  confidence Float   @default(1.0) // 0.0-1.0, lowered when extraction was noisy
  // dedupKey lets us collapse near-duplicate extractions ("send the deck"
  // detected twice across reply chain) without storing fuzzy matchers in DB.
  dedupKey   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  path CommitmentPath?

  @@unique([userId, dedupKey])
  @@index([userId, status, dueAt])
  @@index([userId, threadId])
}

// AI-generated step-by-step fulfillment plan for a commitment.
// Built by backward chaining from the due date. Each step can map to a Task
// or CalendarEvent (taskId / eventId) once the user approves the plan.
model CommitmentPath {
  id           String     @id @default(uuid())
  commitmentId String     @unique
  commitment   Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)

  // JSON array of PathStep: { step, action, dueIso, estimatedMinutes, taskId?, eventId? }
  steps   Json
  builtAt DateTime @default(now())
  model   String?

  @@index([commitmentId])
}

enum CommitmentStatus {
  OPEN
  DONE
  DISMISSED
  SNOOZED
}

enum CommitmentKind {
  DELIVERABLE
  FOLLOW_UP
  DECISION
  MEETING
  REVIEW
}

enum CommitmentOwner {
  USER
  COUNTERPARTY
  TEAM
  UNKNOWN
}

enum CommitmentSource {
  EMAIL
  CHAT
  SLACK
  NOTE
  CALENDAR
}

// ─── Feedback Ledger ───────────────────────────────────────────────────────
// Captures every signal the user gives Eve about what was useful — approve,
// reject, edit, ignore, dismiss, snooze. Step 8 of the Attention OS roadmap
// uses this ledger as the substrate for policy extraction (Step 8.2) and
// agent prompt integration (Step 8.3). This first PR only writes the rows;
// readers stay in follow-up PRs so the data shape can be validated against
// real dogfood traffic before anything depends on it.

model FeedbackEvent {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  source   FeedbackSource
  // FK-by-string into the source row (PendingAction.id, AttentionItem.id, etc.)
  sourceId String

  signal FeedbackSignal

  // Optional context — narrows the policy that future extraction can derive.
  toolName  String? // which tool was being proposed (when relevant)
  recipient String? // email address, contact id, "team", etc.
  threadId  String? // gmail thread id or chat conversation id

  // Original user wording: rejection reason, edit diff snippet, etc.
  evidence String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, signal])
  @@index([userId, recipient])
  @@index([userId, toolName])
}

enum FeedbackSource {
  PENDING_ACTION
  ATTENTION_ITEM
  NOTIFICATION
  DRAFT
}

enum FeedbackSignal {
  APPROVED
  REJECTED
  FAILED
  EDITED
  IGNORED
  SNOOZED
  DISMISSED
}

// Durable Work Graph snapshots. WorkGraph v0 is still inferred from source
// tables, but every summary write-throughs the active contexts here so EVE can
// build longitudinal project memory without waiting for a full graph schema.
model WorkContextSnapshot {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contextKey     String
  kind           String
  title          String
  subtitle       String?
  href           String?
  risk           String
  reasons        Json
  signals        Json
  people         Json
  lastActivityAt DateTime
  generatedAt    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contextKey])
  @@index([userId, risk, lastActivityAt])
}

// User-enabled operating patterns. Recommendations can stay read-only, but an
// activation tells EVE to bias ranking, briefings, and future playbook work
// around that domain.
model ActivatedPlaybook {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playbookId String
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, playbookId])
  @@index([userId, status])
}

// User controls over extracted feedback policies. The extractor remains
// conservative; this table records which candidates the user explicitly wants
// EVE to apply or ignore.
model FeedbackPolicyPreference {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateId String
  kind        String
  toolName    String
  recipient   String?
  action      String   @default("ACTIVE") // ACTIVE | IGNORED
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, candidateId])
  @@index([userId, action])
  @@index([userId, toolName])
}

// ─── Contact Trust Score ───────────────────────────────────────────────────
// Tracks how reliably a counterparty (identified by email) fulfills commitments.
// Updated whenever a COUNTERPARTY commitment transitions to DONE with a known dueAt.
// Confidence rating: "reliable" ≥80% on-time, "mostly_reliable" ≥50%, "unreliable" <50%.
// Requires ≥3 tracked commitments before issuing a badge.
model ContactTrustScore {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactEmail String   // counterparty email, lowercased
  displayName  String?
  // raw counters — never computed on the fly so queries are O(1)
  totalCount     Int      @default(0)
  onTimeCount    Int      @default(0)
  lateCount      Int      @default(0)
  totalDelayDays Int      @default(0) // sum of days late (for avg computation)
  lastUpdatedAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, contactEmail])
  @@index([userId])
}

// Public early-access waitlist. Submissions land here before the founder
// adds the email to the Google Cloud Console Test users list and approves
// access. No FK to User — these are people without accounts yet.
model Waitlist {
  id         String         @id @default(uuid())
  email      String         @unique
  name       String?
  useCase    String?        @db.VarChar(500)
  status     WaitlistStatus @default(PENDING)
  approvedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([status, createdAt])
}

enum WaitlistStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── LLM cost ledger ───────────────────────────────────────────────────────
// Per-user daily LLM spend so the engine can enforce a hard cap before
// each model call (see config.DAILY_COST_CAP_CENTS). One row per
// (user, date in YYYY-MM-DD UTC). `cents` is monotonically incremented as
// calls succeed. Free models add 0 — they still appear so we can see
// "how active was this user today" even when the cost is zero.
model LlmCostLedger {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey      String   // "YYYY-MM-DD" in UTC, stable for fast upsert
  cents       Int      @default(0) // accumulated USD cents
  callCount   Int      @default(0)
  lastModel   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, dayKey])
  @@index([userId, dayKey])
}

// ─── LLM usage log ─────────────────────────────────────────────────────────
// Ground-truth token accounting: one row per successful provider call,
// written at the createCompletion/createVisionCompletion chokepoints
// (openai.ts) with the ACTUAL usage the provider returned and the
// provider+model that actually served the request after failover. The
// pre-bill estimate is stored alongside so estimate-vs-reality drift is
// measurable. Cost gates still run on estimates (cost-guard.ts /
// LlmCostLedger) — this table never gates anything.
// userId is nullable so system-initiated calls are captured too; SetNull on
// user deletion keeps the cost history (rows carry token counts only, no
// content).
model LlmUsageLog {
  id                 String   @id @default(uuid())
  userId             String? // null = system-initiated call (no user accounting)
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider           String // "openrouter" | "gemini"
  model              String // model that actually served the call (post-failover)
  promptTokens       Int      @default(0)
  completionTokens   Int      @default(0)
  totalTokens        Int      @default(0)
  usageMissing       Boolean  @default(false) // provider returned no usage (e.g. streaming)
  estimatedCostCents Int      @default(0) // what the pre-bill gate charged for this call
  source             String   @default("foreground") // "foreground" | "background"
  createdAt          DateTime @default(now())

  @@index([userId, createdAt])
}
