{
  "name": "@klorn/desktop",
  "version": "0.1.0",
  "description": "Klorn desktop shell — a personal command center that wraps the Klorn web app and reads the shared ontology.",
  "main": "dist/main.js",
  "type": "module",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "tsc && cp src/inspector.html src/inspector.css dist/",
    "typecheck": "tsc --noEmit",
    "dev": "tsc && cp src/inspector.html src/inspector.css dist/ && electron .",
    "start": "electron .",
    "test": "vitest run",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^25.3.0",
    "electron": "^33.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
